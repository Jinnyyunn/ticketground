{
  "name": "ticketground-platform",
  "version": "0.3.1",
  "private": true,
  "type": "module",
  "description": "Ticketground ticket marketplace with a Next.js public frontend and backend API.",
  "author": "Ticketground",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Jinnyyunn/ticketground.git"
  },
  "homepage": "https://github.com/Jinnyyunn/ticketground",
  "bugs": {
    "url": "https://github.com/Jinnyyunn/ticketground/issues"
  },
  "keywords": [
    "ticketground",
    "ticketing",
    "resale",
    "nextjs",
    "tailwindcss",
    "backend-api"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "node server.js",
    "build": "next build",
    "start": "NODE_ENV=production node server.js",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && NODE_ENV=production node --test --test-concurrency=1 tests/*.test.mjs",
    "check": "npm run lint && npm run typecheck && npm test"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.6.0",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.1.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "playwright": "^1.61.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
